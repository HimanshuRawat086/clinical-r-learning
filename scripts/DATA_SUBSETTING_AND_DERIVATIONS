# Step 3: Read TXT File
#--------------------------------------------------
aa <- read.table("Dummy_txt.txt", sep="", header=FALSE)
str(aa)

#--------------------------------------------------
# Step 4: Read CSV File
#--------------------------------------------------
emp <- read.csv("employee_data_exported_01.csv")
str(emp)

#--------------------------------------------------
# Step 5: Read Excel File
#--------------------------------------------------
library(readxl)
pop <- read_excel("Population.xlsx")
str(pop)

#--------------------------------------------------
# Step 6: Data Subsetting - TXT
#--------------------------------------------------
aa[1,]
aa[,1]
aa[1,1]
aa[1:5,]

#--------------------------------------------------
# Step 7: Data Subsetting - EMP
#--------------------------------------------------
emp[1:5,]
emp[,1]
emp[1,2]

#--------------------------------------------------
# Step 8: Conditional Filtering
#--------------------------------------------------
emp[emp$Salary > 50000,]

#--------------------------------------------------
# Step 9: Structure and Column Names
#--------------------------------------------------
colnames(emp)
str(emp)

#--------------------------------------------------
# Step 10: Derivation
#--------------------------------------------------
emp$Bonus <- emp$salary * 0.10

#--------------------------------------------------
# Step 11: Summary Statistics
#--------------------------------------------------
summary(emp)
summary(pop)

#--------------------------------------------------
# Step 12: Pattern Matching
#--------------------------------------------------
text <- c("Cat", "Dog", "Camel", "Beer", "elephant", "Programming", "bce")

grep("[aeiou]", text, value=TRUE)
grep("^[aeious]", text, value=TRUE)
grep("[aeiou]$", text, value=TRUE)
grep("[^aeious]", text, value=TRUE)
