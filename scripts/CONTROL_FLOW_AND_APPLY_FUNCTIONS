#--------------------------------------------------
# Step 5: For Loops
#--------------------------------------------------
for(i in 1:5){
  print(i)
}

for(i in 1:5){
  print(paste0("Value: ", i))
}

x <- c("a","b","c")
for(i in x){
  print(i)
}

#--------------------------------------------------
# Step 6: Built-in Constants
#--------------------------------------------------
letters[1:5]
LETTERS[1:5]

#--------------------------------------------------
# Step 7: Repeat Loop
#--------------------------------------------------
v <- "Hello"
x <- 1

repeat{
  print(v)
  print(x)
  x <- x + 1
  if(x >= 3){
    break
  }
}

#--------------------------------------------------
# Step 8: While Loop
#--------------------------------------------------
x <- 0
while(x <= 3){
  print(x)
  x <- x + 1
}

#--------------------------------------------------
# Step 9: Conditional Check
#--------------------------------------------------
a <- 5
if(is.integer(a)){
  print("Integer")
} else {
  print("Not Integer")
}

a <- 5L

#--------------------------------------------------
# Step 10: Nested Loop
#--------------------------------------------------
for(j in 1:2){
  for(i in 1:3){
    print(i)
  }
}

#--------------------------------------------------
# Step 11: Ifelse
#--------------------------------------------------
marks <- c(50,60,80,20)
result <- ifelse(marks >= 60, "Pass", "Fail")

#--------------------------------------------------
# Step 12: dplyr Case_when
#--------------------------------------------------
library(dplyr)

df <- data.frame(marks=c(50,60,80,30))

df <- df %>%
  mutate(result = case_when(
    marks >= 75 ~ "Distinction",
    marks >= 60 ~ "First",
    TRUE ~ "Fail"
  ))

#--------------------------------------------------
# Step 13: Apply Family
#--------------------------------------------------
x <- list(a=1:5, b=6:10)

lapply(x, mean)
sapply(x, mean)

#--------------------------------------------------
# Step 14: Split & tapply
#--------------------------------------------------
x <- c(rnorm(10), runif(10))
f <- gl(2,10)

split(x, f)

#--------------------------------------------------
# Step 15: Matrix Operations
#--------------------------------------------------
mat <- matrix(1:9, nrow=3)

apply(mat, 1, sum)
apply(mat, 2, mean)

rowSums(mat)
colMeans(mat)

#--------------------------------------------------
# Step 16: tapply
#--------------------------------------------------
x <- c(rnorm(10), runif(10))
f <- gl(2,20)

tapply(x, f, mean)

#--------------------------------------------------
# Step 17: mapply
#--------------------------------------------------
mapply(rep, 1:3, 3:1)

mult <- function(u,v){
  (u + v) * 2
}

mapply(mult, c(1,2), c(3,4))

#--------------------------------------------------
# Step 18: Vectorization
#--------------------------------------------------
sumsq <- function(mu, sigma, x){
  sum(((x - mu)/sigma)^2)
}

vec_fun <- Vectorize(sumsq, c("mu","sigma"))

vec_fun(1:3, 1:3, rnorm(50))

#--------------------------------------------------
# Step 19: Apply on Data Frame
#--------------------------------------------------
data <- data.frame(x1=rnorm(10), x2=rnorm(10))

data2 <- apply(data, 2, function(x){
  ifelse(x >= 0.5, 1, 0)
})
